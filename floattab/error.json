/**
 * offscreen.js — FloatTab Mirror Mode Handler (v2.0)
 *
 * Runs in the hidden offscreen document (MV3).
 * Responsibilities:
 * - Manage MULTIPLE concurrent tab capture sessions via a Map keyed by tabId
 * - On START_MIRROR_PIP { tabId, streamId }: create a dynamic <video> element,
 *   acquire the tab capture stream, play it, and open native video PiP
 * - On STOP_MIRROR_PIP { tabId }: tear down that specific tab's stream and video element
 * - Notify the service worker when any stream ends or is closed by the user,
 *   always including the tabId so the SW can update pipRegistry correctly
 */

"use strict";

/**
 * Sessions map: one entry per currently-mirrored tab.
 *
 * Key:   tabId (number)
 * Value: { stream: MediaStream, video: HTMLVideoElement }
 *
 * @type {Map<number, { stream: MediaStream, video: HTMLVideoElement }>}
 */
const sessions = new Map();

// ---------------------------------------------------------------------------
// Message listener
// ---------------------------------------------------------------------------

chrome.runtime.onMessage.addListener((message, _sender, sendResponse) => {
  if (message.type === "START_MIRROR_PIP") {
    startMirrorPiP(message.tabId, message.streamId)
      .then(() => sendResponse({ success: true }))
      .catch((err) => {
        console.error("[FloatTab Offscreen] startMirrorPiP error:", err);
        sendResponse({ success: false, error: err.message });
      });
    return true; // Keep channel open for async response
  }

  if (message.type === "STOP_MIRROR_PIP") {
    stopMirrorPiP(message.tabId);
    sendResponse({ success: true });
    return false;
  }
});

// ---------------------------------------------------------------------------
// Start mirror PiP for a specific tab
// ---------------------------------------------------------------------------

/**
 * Acquires the tab capture stream for `tabId` and opens a native video PiP window.
 *
 * If a session already exists for this tabId (e.g. user re-floats the same tab),
 * the old session is torn down cleanly before starting the new one.
 *
 * @param {number} tabId   - The id of the tab being mirrored
 * @param {string} streamId - The stream ID returned by chrome.tabCapture.getMediaStreamId
 */
async function startMirrorPiP(tabId, streamId) {
  // Clean up any pre-existing session for this tabId (idempotent swap)
  if (sessions.has(tabId)) {
    stopMirrorPiP(tabId);
  }

  // Acquire the tab's video stream using the provided streamId.
  const stream = await navigator.mediaDevices.getUserMedia({
    video: {
      mandatory: {
        chromeMediaSource: "tab",
        chromeMediaSourceId: streamId,
      },
    },
    audio: false, // v2.0: audio routing is a non-goal; each tab keeps its own audio
  });

  // Create a dedicated <video> element for this tab's stream.
  // It is hidden in the DOM; only the PiP window is visible to the user.
  const video = document.createElement("video");
  video.muted = true;
  video.style.cssText = "position:fixed;top:-9999px;left:-9999px;width:1px;height:1px;";
  video.id = `floattab-video-${tabId}`;
  document.body.appendChild(video);

  // Attach the stream and play
  video.srcObject = stream;
  await video.play();

  // Open native video PiP for this stream.
  // Chrome creates a separate floating OS window per requestPictureInPicture() call.
  await video.requestPictureInPicture();

  // Persist the session
  sessions.set(tabId, { stream, video });

  // ── Event: user closes the PiP window via the native close button ──
  video.addEventListener(
    "leavepictureinpicture",
    () => {
      stopMirrorPiP(tabId);
      chrome.runtime
        .sendMessage({ type: "MIRROR_PIP_ENDED", tabId })
        .catch(() => {});
    },
    { once: true }
  );

  // ── Event: stream ends unexpectedly (tab closed, capture revoked, etc.) ──
  stream.getVideoTracks()[0].addEventListener("ended", () => {
    stopMirrorPiP(tabId);
    chrome.runtime
      .sendMessage({ type: "MIRROR_PIP_ENDED", tabId })
      .catch(() => {});
  });

  // ── DRM detection: if the video readyState never advances after 3 s ──
  setTimeout(() => {
    const session = sessions.get(tabId);
    if (session && session.video.readyState === HTMLMediaElement.HAVE_NOTHING) {
      chrome.runtime
        .sendMessage({ type: "MIRROR_PIP_DRM_DETECTED", tabId })
        .catch(() => {});
    }
  }, 3000);
}

// ---------------------------------------------------------------------------
// Stop / teardown for a specific tab
// ---------------------------------------------------------------------------

/**
 * Stops the media stream and removes the video element for `tabId`.
 * Exits PiP on that element if it is currently the picture-in-picture element.
 *
 * @param {number} tabId
 */
function stopMirrorPiP(tabId) {
  const session = sessions.get(tabId);
  if (!session) return;

  const { stream, video } = session;

  // Stop all media tracks
  stream.getTracks().forEach((t) => t.stop());

  // Detach stream from the video element
  video.srcObject = null;

  // Exit PiP only if this specific video is currently the PiP element
  if (document.pictureInPictureElement === video) {
    document.exitPictureInPicture().catch(() => {});
  }

  // Remove the element from the DOM
  video.remove();

  sessions.delete(tabId);
}
 